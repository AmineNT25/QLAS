MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/qlas
JWT_SECRET=your-super-secret-key
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=LAS <noreply@yourdomain.com>

# Agency branding — injected into welcome emails via {{agency_*}} placeholders.
# Set these on Vercel and Railway. Never stored in MongoDB.
AGENCY_NAME="Your Agency Name"
AGENCY_LOGO_URL="https://cdn.youragency.com/logo.png"
AGENCY_WEBSITE="https://youragency.com"
AGENCY_SUPPORT_EMAIL="hello@youragency.com"
